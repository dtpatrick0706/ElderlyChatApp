#:kivy 2.0.0

<ChatMessage>:
    canvas.before:
        Color:
            rgba: (0.9, 0.9, 0.9, 1) if root.is_user else (0.8, 0.9, 1, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10, 10, 10, 10]

<ChatScrollView>:
    canvas.before:
        Color:
            rgba: (1, 1, 1, 1)
        Rectangle:
            pos: self.pos
            size: self.size

